---
const year = new Date().getFullYear();
---

<footer class="bg-surface border-t border-border mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-1 mb-3">
          <span class="font-display text-xl font-bold text-gold-primary">Byznys</span>
          <span class="font-display text-xl font-bold text-text-primary">Denne</span>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed mb-4 max-w-xs">
          Finance, investice a podnikání — bez zbytečných keců.
        </p>
        <a
          href="https://instagram.com/byznysdenne"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-text-secondary hover:text-gold-primary transition-colors duration-200 text-sm font-medium"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @byznysdenne
        </a>
      </div>

      <!-- Obsah -->
      <div>
        <h4 class="font-display font-bold text-text-primary mb-4 text-sm uppercase tracking-wider">Obsah</h4>
        <ul class="space-y-2.5">
          <li><a href="/clanky" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Všechny články</a></li>
          <li><a href="/zacatecnik" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Pro začátečníky</a></li>
          <li><a href="/slovnik" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Slovník pojmů</a></li>
          <li><a href="/o-nas" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">O nás</a></li>
        </ul>
      </div>

      <!-- Nástroje -->
      <div>
        <h4 class="font-display font-bold text-text-primary mb-4 text-sm uppercase tracking-wider">Nástroje</h4>
        <ul class="space-y-2.5">
          <li><a href="/trhy" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Živé trhy</a></li>
          <li><a href="/kalkulacka" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Kalkulačky</a></li>
          <li><a href="/index-trhu" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Index trhu</a></li>
          <li><a href="/ulozene" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Uložené články</a></li>
        </ul>
      </div>

      <!-- Kalkulačky -->
      <div>
        <h4 class="font-display font-bold text-text-primary mb-4 text-sm uppercase tracking-wider">Kalkulačky</h4>
        <ul class="space-y-2.5">
          <li><a href="/kalkulacka/investicni" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Investiční</a></li>
          <li><a href="/kalkulacka/hypoteka" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Hypoteční</a></li>
          <li><a href="/kalkulacka/mzda" class="text-text-secondary text-sm hover:text-gold-primary transition-colors duration-200">Mzdová (čistá mzda)</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-secondary text-xs">
        © {year} Byznys Denne. Všechna práva vyhrazena.
      </p>
      <p class="text-text-secondary text-xs">
        Obsah má pouze informační charakter, není investiční poradenství.
      </p>
    </div>
  </div>
</footer>
