---
interface Props {
  points: string[];
}
const { points } = Astro.props;
---

{points && points.length > 0 && (
  <div class="my-8 bg-gold-primary/5 border-l-4 border-gold-primary rounded-r-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-gold-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
      </svg>
      <span class="text-gold-primary text-sm font-bold uppercase tracking-wider">Klíčové body článku</span>
    </div>
    <ul class="space-y-2.5">
      {points.map(point => (
        <li class="flex items-start gap-3 text-text-secondary text-sm leading-relaxed">
          <span class="text-gold-primary font-bold mt-0.5 flex-shrink-0">✓</span>
          <span>{point}</span>
        </li>
      ))}
    </ul>
  </div>
)}
