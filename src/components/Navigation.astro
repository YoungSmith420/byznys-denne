---
const navLinks = [
  { href: '/clanky', label: 'Články' },
  { href: '/trhy', label: '📊 Trhy' },
  { href: '/kalkulacka', label: 'Kalkulačka' },
  { href: '/slovnik', label: 'Slovník' },
  { href: '/index-trhu', label: 'Index trhu' },
  { href: '/o-nas', label: 'O nás' },
  { href: '/zacatecnik', label: '🎓 Začátečník' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="main-nav" class="sticky top-0 z-50 transition-all duration-300 border-b border-transparent" data-scrolled="false">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-1 group">
        <span class="font-display text-2xl font-bold text-gold-primary group-hover:text-gold-light transition-colors duration-200">Byznys</span>
        <span class="font-display text-2xl font-bold text-text-primary">Denne</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-3 lg:gap-4">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link text-xs font-medium ${isActive(link.href) ? 'active text-gold-primary' : ''}`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://instagram.com/byznysdenne"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold text-sm px-5 py-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          Instagram
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-text-secondary hover:text-text-primary transition-colors" aria-label="Menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface/95 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-3 py-3 rounded-lg text-sm font-medium transition-colors duration-200 ${
            isActive(link.href)
              ? 'bg-gold-primary/10 text-gold-primary'
              : 'text-text-secondary hover:text-text-primary hover:bg-card'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-2 border-t border-border">
        <a
          href="https://instagram.com/byznysdenne"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold w-full text-sm px-5 py-3 mt-2"
        >
          Instagram
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  // Scroll behaviour: add bg blur when scrolled
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      nav?.classList.add('bg-background/90', 'backdrop-blur-md', 'border-border');
      nav?.classList.remove('border-transparent');
    } else {
      nav?.classList.remove('bg-background/90', 'backdrop-blur-md', 'border-border');
      nav?.classList.add('border-transparent');
    }
  }, { passive: true });

  // Mobile toggle
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
