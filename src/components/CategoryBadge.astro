---
interface Props {
  category: 'investice' | 'podnikani' | 'finance' | 'krypto';
}

const { category } = Astro.props;

const config = {
  investice: {
    label: 'Investice',
    classes: 'bg-yellow-900/30 text-yellow-400 border-yellow-700/50',
  },
  podnikani: {
    label: 'Podnikání',
    classes: 'bg-green-900/30 text-green-400 border-green-700/50',
  },
  finance: {
    label: 'Finance',
    classes: 'bg-blue-900/30 text-blue-400 border-blue-700/50',
  },
  krypto: {
    label: 'Krypto',
    classes: 'bg-orange-900/30 text-orange-400 border-orange-700/50',
  },
};

const { label, classes } = config[category];
---

<span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold border ${classes}`}>
  {label}
</span>
