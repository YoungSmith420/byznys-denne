---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LeadMagnetPopup from '../components/LeadMagnetPopup.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
}

const {
  title,
  description = 'Finance, investice a podnikání — bez zbytečných keců.',
  image = '/og-default.png',
  type = 'website',
  publishedDate,
} = Astro.props;

const siteUrl = 'https://byznysdenne.cz';
const fullTitle = title === 'Byznys Denne' ? title : `${title} | Byznys Denne`;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Byznys Denne",
      "description": "Finance, investice a podnikání — bez zbytečných keců.",
      "inLanguage": "cs",
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Byznys Denne",
      "url": siteUrl,
      "sameAs": ["https://www.instagram.com/byznysdenne/"],
    },
  ],
};
---

<!doctype html>
<html lang="cs" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#D4AF37" />

    <!-- Theme: set before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersLight =
            window.matchMedia &&
            window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = stored || (prefersLight ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <!-- Hreflang -->
    <link rel="alternate" hreflang="cs" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- OG -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Byznys Denne" />
    <meta property="og:locale" content="cs_CZ" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <title>{fullTitle}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- Fonts (display=swap = font-display: swap) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- WebSite + Organization JSON-LD (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

    {type === 'article' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "url": canonicalUrl,
        "datePublished": publishedDate,
        "inLanguage": "cs",
        "author": {
          "@type": "Organization",
          "name": "Byzák & tým Byznys Denne",
          "@id": `${siteUrl}/#organization`,
        },
        "publisher": {
          "@type": "Organization",
          "name": "Byznys Denne",
          "url": siteUrl,
          "@id": `${siteUrl}/#organization`,
        },
      })} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Global popup + sticky mobile CTA -->
    <LeadMagnetPopup />
    <StickyMobileCTA />

    <!-- Global scroll-reveal + animated counters -->
    <script is:inline>
      (function () {
        var reduce =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ---- Scroll reveal ----
        var revealEls = document.querySelectorAll('.reveal');
        if (reduce) {
          revealEls.forEach(function (el) { el.classList.add('is-visible'); });
        } else if ('IntersectionObserver' in window) {
          var ro = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  ro.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
          );
          revealEls.forEach(function (el) { ro.observe(el); });
        } else {
          revealEls.forEach(function (el) { el.classList.add('is-visible'); });
        }

        // ---- Animated counters ----
        // Markup: <span data-counter="12000" data-suffix="+" data-prefix="">0</span>
        function animateCounter(el) {
          var target = parseFloat(el.getAttribute('data-counter')) || 0;
          var prefix = el.getAttribute('data-prefix') || '';
          var suffix = el.getAttribute('data-suffix') || '';
          var decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);
          var duration = parseInt(el.getAttribute('data-duration') || '1600', 10);
          var startTime = null;
          var nf = new Intl.NumberFormat('cs-CZ', {
            minimumFractionDigits: decimals,
            maximumFractionDigits: decimals,
          });

          function step(ts) {
            if (!startTime) startTime = ts;
            var progress = Math.min((ts - startTime) / duration, 1);
            // easeOutExpo
            var eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            var value = target * eased;
            el.textContent = prefix + nf.format(value) + suffix;
            if (progress < 1) requestAnimationFrame(step);
            else el.textContent = prefix + nf.format(target) + suffix;
          }
          requestAnimationFrame(step);
        }

        var counters = document.querySelectorAll('[data-counter]');
        if (reduce) {
          counters.forEach(function (el) {
            var t = parseFloat(el.getAttribute('data-counter')) || 0;
            var d = parseInt(el.getAttribute('data-decimals') || '0', 10);
            el.textContent =
              (el.getAttribute('data-prefix') || '') +
              new Intl.NumberFormat('cs-CZ', {
                minimumFractionDigits: d,
                maximumFractionDigits: d,
              }).format(t) +
              (el.getAttribute('data-suffix') || '');
          });
        } else if ('IntersectionObserver' in window) {
          var co = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  animateCounter(entry.target);
                  co.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.5 }
          );
          counters.forEach(function (el) { co.observe(el); });
        } else {
          counters.forEach(function (el) { animateCounter(el); });
        }
      })();
    </script>
  </body>
</html>
