---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Investiční kalkulačka — složené úročení"
  description="Spočítej si, kolik budou mít tvé investice za 10, 20 nebo 40 let. Kalkulačka složeného úroku zdarma."
>

  <!-- Hero -->
  <section class="pt-16 pb-10 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/kalkulacka" class="inline-flex items-center gap-1.5 text-text-secondary text-sm hover:text-gold-primary transition-colors mb-4">
        ← Všechny kalkulačky
      </a>
      <p class="text-gold-primary text-sm font-semibold uppercase tracking-widest mb-3">Nástroje</p>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-text-primary mb-4">
        Investiční kalkulačka
      </h1>
      <p class="text-text-secondary text-lg max-w-2xl">
        Vidíš, kolik tvé peníze vyrostou díky složenému úroku. Pohybuj slidery — výsledky se mění živě.
      </p>
    </div>
  </section>

  <!-- Main layout -->
  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-[1fr_380px] gap-10">

        <!-- Sliders -->
        <div class="space-y-8">

          <!-- Slider: počáteční investice -->
          <div class="slider-group">
            <div class="flex justify-between items-baseline mb-3">
              <label class="text-text-primary font-semibold">Počáteční investice</label>
              <div class="flex items-baseline gap-1">
                <span id="val-initial" class="text-gold-primary font-display text-2xl font-bold">10 000</span>
                <span class="text-text-secondary text-sm">Kč</span>
              </div>
            </div>
            <input id="initial" type="range" min="0" max="500000" step="1000" value="10000" class="calc-slider" />
            <div class="flex justify-between text-xs text-text-secondary mt-1">
              <span>0 Kč</span><span>500 000 Kč</span>
            </div>
          </div>

          <!-- Slider: měsíční příspěvek -->
          <div class="slider-group">
            <div class="flex justify-between items-baseline mb-3">
              <label class="text-text-primary font-semibold">Měsíční příspěvek</label>
              <div class="flex items-baseline gap-1">
                <span id="val-monthly" class="text-gold-primary font-display text-2xl font-bold">2 000</span>
                <span class="text-text-secondary text-sm">Kč/měs.</span>
              </div>
            </div>
            <input id="monthly" type="range" min="0" max="50000" step="500" value="2000" class="calc-slider" />
            <div class="flex justify-between text-xs text-text-secondary mt-1">
              <span>0 Kč</span><span>50 000 Kč</span>
            </div>
          </div>

          <!-- Slider: roční výnos -->
          <div class="slider-group">
            <div class="flex justify-between items-baseline mb-3">
              <label class="text-text-primary font-semibold">Očekávaný roční výnos</label>
              <div class="flex items-baseline gap-1">
                <span id="val-rate" class="text-gold-primary font-display text-2xl font-bold">7</span>
                <span class="text-text-secondary text-sm">% ročně</span>
              </div>
            </div>
            <input id="rate" type="range" min="1" max="20" step="0.5" value="7" class="calc-slider" />
            <div class="flex justify-between text-xs text-text-secondary mt-1">
              <span>1 %</span><span>20 %</span>
            </div>
          </div>

          <!-- Slider: počet let -->
          <div class="slider-group">
            <div class="flex justify-between items-baseline mb-3">
              <label class="text-text-primary font-semibold">Počet let</label>
              <div class="flex items-baseline gap-1">
                <span id="val-years" class="text-gold-primary font-display text-2xl font-bold">20</span>
                <span class="text-text-secondary text-sm">let</span>
              </div>
            </div>
            <input id="years" type="range" min="1" max="40" step="1" value="20" class="calc-slider" />
            <div class="flex justify-between text-xs text-text-secondary mt-1">
              <span>1 rok</span><span>40 let</span>
            </div>
          </div>

          <!-- Info note -->
          <p class="text-text-secondary text-xs leading-relaxed border-l-2 border-border pl-4">
            Výpočet je orientační a bere v úvahu roční složené úročení. Skutečné výnosy se liší. Nejedná se o investiční poradenství.
          </p>
        </div>

        <!-- Results panel -->
        <div class="space-y-4">
          <!-- Main result -->
          <div class="bg-card border border-gold-primary/30 rounded-2xl p-8 text-center shadow-[0_0_40px_rgba(212,175,55,0.08)]">
            <p class="text-text-secondary text-sm mb-2 uppercase tracking-widest font-medium">Celková hodnota portfolia</p>
            <p id="result-total" class="font-display text-5xl font-bold text-gold-primary leading-none mb-1">–</p>
            <p class="text-text-secondary text-xs">po <span id="result-years-label">20</span> letech</p>
          </div>

          <!-- Sub results -->
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-card border border-border rounded-xl p-5 text-center">
              <div class="w-3 h-3 rounded-full bg-chart-blue mx-auto mb-3"></div>
              <p class="text-text-secondary text-xs mb-1">Vloženo celkem</p>
              <p id="result-invested" class="font-display text-xl font-bold text-text-primary">–</p>
            </div>
            <div class="bg-card border border-border rounded-xl p-5 text-center">
              <div class="w-3 h-3 rounded-full bg-gold-primary mx-auto mb-3"></div>
              <p class="text-text-secondary text-xs mb-1">Výnosy (zhodnocení)</p>
              <p id="result-returns" class="font-display text-xl font-bold text-accent-green">–</p>
            </div>
          </div>

          <!-- Ratio bar -->
          <div class="bg-card border border-border rounded-xl p-5">
            <p class="text-text-secondary text-xs mb-3">Poměr: vloženo vs. výnosy</p>
            <div class="h-4 rounded-full overflow-hidden bg-chart-blue flex">
              <div id="ratio-bar" class="h-full bg-gold-primary rounded-full transition-all duration-500" style="width:50%"></div>
            </div>
            <div class="flex justify-between mt-2 text-xs text-text-secondary">
              <span>Vloženo</span><span>Výnosy</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Chart -->
      <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-display text-2xl font-bold text-text-primary">Růst portfolia po letech</h2>
          <div class="flex items-center gap-5 text-xs text-text-secondary">
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm bg-chart-blue inline-block"></span> Vloženo</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm bg-gold-primary inline-block"></span> Výnosy</span>
          </div>
        </div>
        <div class="bg-card border border-border rounded-2xl p-4 overflow-hidden">
          <svg id="chart-svg" width="100%" height="260" viewBox="0 0 800 260" preserveAspectRatio="xMidYMid meet"></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 border-t border-border mt-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">📚</div>
      <h2 class="font-display text-3xl font-bold text-text-primary mb-3">
        Chceš vědět jak investovat?
      </h2>
      <p class="text-text-secondary mb-6">
        Přečti si naše průvodce — od prvních 1 000 Kč až po pokročilé strategie.
      </p>
      <a href="/clanky" class="btn-gold px-8 py-4 text-base">
        Přečíst články o investování →
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const fmt = (n: number) =>
    new Intl.NumberFormat('cs-CZ', { maximumFractionDigits: 0 }).format(n) + ' Kč';

  // Read live theme colors from CSS variables so charts/sliders match the active theme
  function themeColors() {
    const s = getComputedStyle(document.documentElement);
    const v = (name: string) => `rgb(${s.getPropertyValue(name).trim()})`;
    return {
      gold: v('--color-gold-primary'),
      track: v('--color-border'),
      text: v('--color-text-secondary'),
      blue: v('--color-chart-blue'),
    };
  }

  function updateSlider(el: HTMLInputElement) {
    const min = +el.min, max = +el.max, val = +el.value;
    const pct = ((val - min) / (max - min)) * 100;
    const c = themeColors();
    el.style.background = `linear-gradient(to right, ${c.gold} ${pct}%, ${c.track} ${pct}%)`;
  }

  function calculate() {
    const pv = +(<HTMLInputElement>document.getElementById('initial')).value;
    const pmt = +(<HTMLInputElement>document.getElementById('monthly')).value;
    const annualRate = +(<HTMLInputElement>document.getElementById('rate')).value;
    const years = +(<HTMLInputElement>document.getElementById('years')).value;

    const r = annualRate / 100 / 12;

    const yearlyFV: number[] = [];
    for (let y = 1; y <= years; y++) {
      const n = y * 12;
      const fv = r === 0
        ? pv + pmt * n
        : pv * Math.pow(1 + r, n) + pmt * ((Math.pow(1 + r, n) - 1) / r);
      yearlyFV.push(fv);
    }

    const totalInvested = pv + pmt * years * 12;
    const finalValue = yearlyFV[yearlyFV.length - 1];
    const returns = finalValue - totalInvested;
    const returnsPct = finalValue > 0 ? (returns / finalValue) * 100 : 0;

    document.getElementById('result-total')!.textContent = fmt(finalValue);
    document.getElementById('result-invested')!.textContent = fmt(totalInvested);
    document.getElementById('result-returns')!.textContent = fmt(returns);
    document.getElementById('result-years-label')!.textContent = String(years);
    (<HTMLElement>document.getElementById('ratio-bar')).style.width = `${returnsPct}%`;

    drawChart(yearlyFV, pv, pmt, years);
  }

  function drawChart(yearlyFV: number[], pv: number, pmt: number, years: number) {
    const svgEl = document.getElementById('chart-svg')!;
    const W = 800, H = 260;
    const padT = 20, padB = 45, padL = 80, padR = 20;
    const cW = W - padL - padR;
    const cH = H - padT - padB;

    const maxVal = yearlyFV[yearlyFV.length - 1] || 1;
    const slotW = cW / years;
    const barW = Math.max(slotW * 0.65, 2);
    const barOffset = (slotW - barW) / 2;
    const c = themeColors();

    let html = '';

    for (let i = 0; i <= 4; i++) {
      const y = padT + (cH / 4) * i;
      const val = maxVal * (1 - i / 4);
      const label = val >= 1_000_000
        ? (val / 1_000_000).toFixed(1) + ' M'
        : val >= 1_000
        ? Math.round(val / 1_000) + ' k'
        : Math.round(val).toString();
      html += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="${c.track}" stroke-width="1"/>`;
      html += `<text x="${padL - 8}" y="${y + 4}" text-anchor="end" fill="${c.text}" font-size="11" font-family="Inter,sans-serif">${label}</text>`;
    }

    yearlyFV.forEach((fv, i) => {
      const invested = Math.min(pv + pmt * (i + 1) * 12, fv);
      const ret = fv - invested;
      const x = padL + i * slotW + barOffset;

      const investedH = (invested / maxVal) * cH;
      const retH = (ret / maxVal) * cH;
      const baseY = padT + cH;

      html += `<rect x="${x.toFixed(1)}" y="${(baseY - investedH).toFixed(1)}" width="${barW.toFixed(1)}" height="${investedH.toFixed(1)}" fill="${c.blue}" rx="2"/>`;
      if (ret > 0) {
        html += `<rect x="${x.toFixed(1)}" y="${(baseY - investedH - retH).toFixed(1)}" width="${barW.toFixed(1)}" height="${retH.toFixed(1)}" fill="${c.gold}" rx="2"/>`;
      }

      const yr = i + 1;
      const showLabel = years <= 20 ? true : yr % 5 === 0 || yr === years;
      if (showLabel) {
        html += `<text x="${(x + barW / 2).toFixed(1)}" y="${H - 8}" text-anchor="middle" fill="${c.text}" font-size="11" font-family="Inter,sans-serif">${yr}</text>`;
      }
    });

    html += `<text x="${W / 2}" y="${H - 0}" text-anchor="middle" fill="${c.text}" font-size="11" font-family="Inter,sans-serif">Rok</text>`;
    svgEl.innerHTML = html;
  }

  const sliders = document.querySelectorAll<HTMLInputElement>('.calc-slider');
  const displays: Record<string, string> = {
    initial: 'val-initial',
    monthly: 'val-monthly',
    rate: 'val-rate',
    years: 'val-years',
  };

  sliders.forEach(slider => {
    updateSlider(slider);
    slider.addEventListener('input', () => {
      updateSlider(slider);
      const dispId = displays[slider.id];
      if (dispId) {
        const val = +slider.value;
        const el = document.getElementById(dispId)!;
        if (slider.id === 'rate') {
          el.textContent = val % 1 === 0 ? String(val) : val.toFixed(1);
        } else {
          el.textContent = new Intl.NumberFormat('cs-CZ').format(val);
        }
      }
      calculate();
    });
  });

  calculate();

  // Re-render sliders + chart when the theme changes
  new MutationObserver(() => {
    sliders.forEach(updateSlider);
    calculate();
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
