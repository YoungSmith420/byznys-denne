async function loadCommodities(silent = false) {
  const skel  = document.getElementById('comm-skel')!;
  const table = document.getElementById('comm-table')!;
  const errEl = document.getElementById('comm-err')!;

  if (!silent) {
    skel.classList.remove('hidden');
    table.classList.add('hidden');
    errEl.classList.add('hidden');
  }

  try {
    const res = await fetch('/api/commodities.json', { signal: AbortSignal.timeout(40_000) });
    if (!res.ok) throw new Error('API ' + res.status);
    const data = await res.json();
    allCommodities = data.commodities ?? [];
  } catch (e) {
    console.error('Commodities error:', e);
    if (!silent) { document.getElementById('comm-skel')!.classList.add('hidden'); errEl.classList.remove('hidden'); }
    return;
  }

  // Při prvním načtení vyber vše
  if (selectedComms.size === 0) {
    allCommodities.forEach(c => selectedComms.add(c.symbol));
  }

  renderCommTable(silent);
  renderCommDropdown();
}

