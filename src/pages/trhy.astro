interface CommodityQ {
  rank:         number;
  symbol:       string;
  name:         string;
  fullName:     string;
  unit:         string;
  w52High:      number | null;
  w52Low:       number | null;
  price:        number;
  change:       number;
  changePct:    number;
  m7ChangePct:  number | null;
  m30ChangePct: number | null;
  w52ChangePct: number | null;
}

let allCommodities: CommodityQ[] = [];
