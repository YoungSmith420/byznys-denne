  dividendPct:  number | null;
  w52High:      number | null;
  w52Low:       number | null;
  price:        number;
  change:       number;
  changePct:    number;
  m7ChangePct:  number | null;
  m30ChangePct: number | null;
  w52ChangePct: number | null;
  logoUrl:      string;
  domain:       string;
}

/** Fetch stocks via our server-side proxy — bypasses CORS */
async function loadStocks(silent = false) {
  const skel  = document.getElementById('stocks-skel')!;
  const table = document.getElementById('stocks-table')!;
  const errEl = document.getElementById('stocks-err')!;

  if (!silent) {
    skel.classList.remove('hidden');
    table.classList.add('hidden');
    errEl.classList.add('hidden');
  }

  let stocks: StockQ[] = [];

  try {
    const res = await fetch('/api/stocks.json', { signal: AbortSignal.timeout(40_000) });
    if (!res.ok) throw new Error('API ' + res.status);
    const data = await res.json();
    stocks = data.stocks ?? [];
  } catch { /* fall through to error state */ }

  if (stocks.length === 0) {
    if (!silent) { skel.classList.add('hidden'); errEl.classList.remove('hidden'); }
    return;
  }

  // ── Build table HTML ──
  const TH_ST = 'color:#A0A0A0;font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em';
  let html = `<table class="w-full bg-card" style="min-width:520px;border-collapse:collapse">`;
  html += `<thead class="sticky-thead"><tr style="border-bottom:1px solid #2a2a2a">
    <th style="padding:.65rem .5rem .65rem 1rem;width:36px;${TH_ST};text-align:center">#</th>
    <th style="padding:.65rem 1rem;width:58px;${TH_ST}">Logo</th>
    <th style="padding:.65rem 1rem;text-align:left;${TH_ST}">Společnost</th>
    <th class="col-md" style="padding:.65rem 1rem;text-align:center;${TH_ST};display:none">Symbol</th>
    <th class="col-lg" style="padding:.65rem 1rem;text-align:right;${TH_ST};display:none">P/E</th>
    <th class="col-lg" style="padding:.65rem 1rem;text-align:right;${TH_ST};display:none">Div %</th>
    <th class="col-lg" style="padding:.65rem 1rem;text-align:right;${TH_ST};display:none">52W MAX</th>
    <th class="col-lg" style="padding:.65rem 1rem;text-align:right;${TH_ST};display:none">52W MIN</th>
    <th style="padding:.65rem 1rem;text-align:right;${TH_ST}">Cena</th>
    <th style="padding:.65rem 1rem;text-align:right;${TH_ST}">24h</th>
    <th class="col-md" style="padding:.65rem 1rem;text-align:right;${TH_ST};display:none">7d</th>
    <th class="col-md" style="padding:.65rem 1rem;text-align:right;${TH_ST};display:none">30d</th>
    <th class="col-md" style="padding:.65rem 1.25rem .65rem 1rem;text-align:right;${TH_ST};display:none">1R</th>
  </tr></thead><tbody>`;

  for (const s of stocks) {
    const col  = pctColor(s.changePct);
    const init = s.symbol.replace('-', '').slice(0, 3);
    const gFav = `https://www.google.com/s2/favicons?domain=${s.domain}&sz=64`;

    html += `<tr class="trhy-row" style="border-bottom:1px solid #2a2a2a">
      <td style="padding:.75rem .5rem .75rem 1rem;width:36px;text-align:center;color:#A0A0A0;font-size:.8rem;font-weight:600;vertical-align:middle">${s.rank}</td>
      <td style="padding:.75rem 1rem;width:58px;vertical-align:middle">
        <div style="width:38px;height:38px;border-radius:8px;background:#111;border:1px solid #2a2a2a;overflow:hidden;display:flex;align-items:center;justify-content:center;position:relative">
          <span style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;color:#D4AF37;z-index:0">${init}</span>
          <img src="${s.logoUrl}" alt="${s.name}" width="26" height="26"
            style="object-fit:contain;position:relative;z-index:1" loading="lazy"
            onerror="if(this.dataset.fb){this.style.display='none'}else{this.dataset.fb=1;this.src='${gFav}'}">
        </div>
      </td>
      <td style="padding:.75rem 1rem;vertical-align:middle">
        <div style="font-weight:600;font-size:.85rem;color:#F5F5F5;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px">${s.name}</div>
      </td>
      <td class="col-md" style="padding:.75rem 1rem;text-align:center;display:none;vertical-align:middle">
        <span style="font-size:.7rem;font-weight:700;background:#1a1a1a;border:1px solid #2a2a2a;color:#A0A0A0;border-radius:4px;padding:2px 8px;white-space:nowrap">${s.symbol}</span>
      </td>
      <td class="col-lg" style="padding:.75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.peRatio != null ? `<div style="font-size:.82rem;font-weight:600;color:#E0C97F;white-space:nowrap">${s.peRatio.toFixed(1)}×</div>` : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
      <td class="col-lg" style="padding:.75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.dividendPct != null ? `<div style="font-size:.82rem;font-weight:600;color:#60a5fa;white-space:nowrap">${s.dividendPct.toFixed(2)}%</div>` : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
      <td class="col-lg" style="padding:.75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.w52High != null ? `<div style="font-size:.82rem;font-weight:600;color:#22c55e;white-space:nowrap">${fmtPrice(s.w52High)}</div>` : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
      <td class="col-lg" style="padding:.75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.w52Low != null ? `<div style="font-size:.82rem;font-weight:600;color:#f87171;white-space:nowrap">${fmtPrice(s.w52Low)}</div>` : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
      <td style="padding:.75rem 1rem;text-align:right;font-size:.88rem;font-weight:600;color:#F5F5F5;white-space:nowrap;vertical-align:middle">${fmtPrice(s.price)}</td>
      <td style="padding:.75rem 1rem;text-align:right;vertical-align:middle">
        <div style="font-size:.88rem;font-weight:600;color:${col};white-space:nowrap">${pctStr(s.changePct)}</div>
        <div style="font-size:.72rem;color:#A0A0A0;margin-top:1px">${s.change >= 0 ? '+' : ''}${s.change.toFixed(2)}</div>
      </td>
      <td class="col-md" style="padding:.75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.m7ChangePct != null
          ? `<div style="font-size:.85rem;font-weight:600;color:${pctColor(s.m7ChangePct)};white-space:nowrap">${pctStr(s.m7ChangePct)}</div>`
          : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
      <td class="col-md" style="padding:.75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.m30ChangePct != null
          ? `<div style="font-size:.85rem;font-weight:600;color:${pctColor(s.m30ChangePct)};white-space:nowrap">${pctStr(s.m30ChangePct)}</div>`
          : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
      <td class="col-md" style="padding:.75rem 1.25rem .75rem 1rem;text-align:right;display:none;vertical-align:middle">
        ${s.w52ChangePct != null
          ? `<div style="font-size:.85rem;font-weight:600;color:${pctColor(s.w52ChangePct)};white-space:nowrap">${pctStr(s.w52ChangePct)}</div>`
          : '<span style="color:#333;font-size:.8rem">—</span>'}
      </td>
    </tr>`;
  }
  html += `</tbody></table>`;

  skel.classList.add('hidden');
  table.innerHTML = html;
  table.classList.remove('hidden');
  applyColVis();
}

