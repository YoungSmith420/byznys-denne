let commDropdownOpen = false;

function renderCommDropdown() {
  const wrap = document.getElementById('comm-filter-wrap');
  if (!wrap || allCommodities.length === 0) return;

  const sel   = selectedComms.size;
  const total = allCommodities.length;
  const allOn = sel === total;

  wrap.classList.remove('hidden');
  wrap.innerHTML = `
    <button id="comm-filter-btn"
      style="display:inline-flex;align-items:center;gap:8px;color:#808080;font-size:.8rem;font-weight:500;
             padding:8px 14px;border:1px solid #2a2a2a;border-radius:8px;background:#0d0d0d;cursor:pointer;
             transition:all .15s;white-space:nowrap">
      <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h18M7 9h10M11 14h2"/>
      </svg>
      Vybrat komodity
      <span style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:99px;padding:1px 8px;
                   font-size:.72rem;font-weight:700;color:${allOn ? '#555' : '#D4AF37'}">${sel}/${total}</span>
      <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 9l6 6 6-6"/>
      </svg>
    </button>
    <div id="comm-dd"
      style="display:none;position:absolute;right:0;top:calc(100% + 6px);z-index:200;
             background:#0f0f0f;border:1px solid #2a2a2a;border-radius:12px;
             min-width:230px;box-shadow:0 12px 40px rgba(0,0,0,.7);overflow:hidden;touch-action:pan-y">
      <div style="padding:8px 14px 9px;border-bottom:1px solid #1e1e1e;
                  display:flex;align-items:center;justify-content:space-between">
        <span style="font-size:.68rem;font-weight:700;color:#444;text-transform:uppercase;letter-spacing:.06em">Komodity</span>
        <button id="comm-toggle-all"
          style="font-size:.75rem;color:#D4AF37;background:none;border:none;cursor:pointer;padding:0">
          ${allOn ? 'Odznačit vše' : 'Označit vše'}
        </button>
      </div>
      <div class="comm-scroll" style="max-height:310px;overflow-y:scroll;overflow-x:hidden;padding:4px 0;-webkit-overflow-scrolling:touch;touch-action:pan-y;overscroll-behavior:contain">
        ${allCommodities.map(c => `
          <label class="comm-dd-item"
            style="display:flex;align-items:center;gap:10px;padding:7px 14px;cursor:pointer;transition:background .1s;touch-action:pan-y">
            <input type="checkbox" value="${c.symbol}" ${selectedComms.has(c.symbol) ? 'checked' : ''}
              style="accent-color:#D4AF37;width:14px;height:14px;cursor:pointer;flex-shrink:0">
            <span style="font-size:.82rem;color:#C0C0C0;flex:1;white-space:nowrap">${c.name}</span>
            <span style="font-size:.68rem;color:#404040;font-family:monospace">${c.symbol}</span>
          </label>`).join('')}
      </div>
    </div>`;

  const btn = document.getElementById('comm-filter-btn')!;
  const dd  = document.getElementById('comm-dd')!;

  btn.addEventListener('click', e => {
    e.stopPropagation();
    commDropdownOpen = !commDropdownOpen;
    dd.style.display = commDropdownOpen ? 'block' : 'none';
  });

  dd.addEventListener('click',      e => e.stopPropagation());
  dd.addEventListener('touchstart', e => e.stopPropagation(), { passive: true });
  dd.addEventListener('touchmove',  e => e.stopPropagation(), { passive: true });
  dd.addEventListener('touchend',   e => e.stopPropagation(), { passive: true });

  document.addEventListener('click', () => {
    if (commDropdownOpen) { commDropdownOpen = false; dd.style.display = 'none'; }
  }, { once: false });

  document.getElementById('comm-toggle-all')?.addEventListener('click', () => {
    if (allOn) {
      selectedComms.clear();
      // Ponech aspoň jednu
      if (allCommodities.length) selectedComms.add(allCommodities[0].symbol);
    } else {
      allCommodities.forEach(c => selectedComms.add(c.symbol));
    }
    renderCommTable();
    renderCommDropdown();
  });

  dd.querySelectorAll<HTMLInputElement>('input[type=checkbox]').forEach(cb => {
    cb.addEventListener('change', () => {
      if (cb.checked) selectedComms.add(cb.value);
      else {
        // Ponech aspoň jednu aktivní
        if (selectedComms.size > 1) selectedComms.delete(cb.value);
        else { cb.checked = true; return; }
      }
      renderCommTable();
      // Jen aktualizuj counter badge bez re-renderu celého dropdownu
      const badge = btn.querySelector('span');
      if (badge) {
        const s = selectedComms.size;
        badge.textContent = `${s}/${total}`;
        badge.style.color = s < total ? '#D4AF37' : '#555';
      }
    });
  });
}

// ════════════════════════════════════════════════════════════════
// AUTO-REFRESH + COUNTDOWN
// ════════════════════════════════════════════════════════════════

const REFRESH_S = 90;
let cdVal    = REFRESH_S;
let cdTimer: ReturnType<typeof setInterval> | null = null;
let busy     = false;

function setTimestamp() {
  const el = document.getElementById('last-updated');
  if (el) el.textContent = `Aktualizováno: ${new Date().toLocaleTimeString('cs-CZ', { hour: '2-digit', minute: '2-digit', second: '2-digit' })}`;
}

function startCountdown() {
  const wrap = document.getElementById('cd-wrap');
  const cdEl = document.getElementById('countdown');
  wrap?.classList.remove('hidden');
  cdVal = REFRESH_S;
  if (cdTimer) clearInterval(cdTimer);
  cdTimer = setInterval(() => {
    cdVal--;
    if (cdEl) cdEl.textContent = String(cdVal);
    if (cdVal <= 0) {
      if (cdTimer) clearInterval(cdTimer);
      refresh(true);
    }
  }, 1000);
}

async function refresh(silent = false) {
  if (busy) return;
  busy = true;

  const btn  = document.getElementById('refresh-btn') as HTMLButtonElement | null;
  const icon = document.getElementById('refresh-icon');
  if (btn)  btn.disabled = true;
  if (icon) { icon.style.transition = 'transform .7s'; icon.style.transform = 'rotate(360deg)'; }

  await Promise.allSettled([loadCrypto(silent), loadStocks(silent), loadCommodities(silent)]);

  setTimestamp();
  busy = false;
  if (btn)  btn.disabled = false;
  if (icon) setTimeout(() => { icon.style.transition = ''; icon.style.transform = ''; }, 750);
  startCountdown();
}

// ── Wire buttons ─────────────────────────────────────────────────
document.getElementById('refresh-btn')  ?.addEventListener('click', () => { if (cdTimer) clearInterval(cdTimer); refresh(false); });
document.getElementById('retry-crypto') ?.addEventListener('click', () => loadCrypto(false));
document.getElementById('retry-stocks') ?.addEventListener('click', () => loadStocks(false));
document.getElementById('retry-comm')   ?.addEventListener('click', () => loadCommodities(false));

// ── Boot ─────────────────────────────────────────────────────────
refresh(false);
</script>
